{
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.sf": true,
    "**/.sfdx": true
  },
  "workbench.colorCustomizations": {
    "statusBar.background": "#2f53a8",
    "activityBar.background": "#2f53a8"
  },
  "salesforce.einsteinForDevelopers.enableAutocompletions": true,
  "salesforce.einsteinForDevelopers.enableAutocompletionsByFileType": {
    "apex": true,
    "javascript": true,
    "css": true,
    "html": true
  },
  "salesforce.einsteinForDevelopers.enable": true,
  "salesforce.einsteinForDevelopers.enableInlineIndicatorForAutocomplete": false,
  "salesforce.einsteinForDevelopers.enableAutocompletionsSleepModeMonitoring": false,
  "salesforce.einsteinForDevelopers.enableSkills": false
}
