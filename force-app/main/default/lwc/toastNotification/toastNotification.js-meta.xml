<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Show Toast Action</masterLabel>
    <targets>
        <target>lightning__AvailableForFlowActions</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AvailableForFlowActions">
            <property name="title" type="String" label="Title" role="inputOnly"/>
            <property name="message" type="String" label="Message" role="inputOnly"/>
            <property name="variant" type="String" label="Variant (success, error, warning, info)" role="inputOnly"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>